{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cryptoposture.github.io/cryptodiff/schemas/policy.schema.json",
  "title": "cryptodiff policy",
  "type": "object",
  "required": ["version", "rules"],
  "properties": {
    "version": { "type": "string" },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "level", "match"],
        "properties": {
          "id": { "type": "string" },
          "level": {
            "type": "string",
            "enum": ["info", "low", "medium", "high", "critical"]
          },
          "match": {
            "type": "object",
            "properties": {
              "category": { "type": "string" },
              "attribute": { "type": "string" },
              "op": {
                "type": "string",
                "enum": ["=", "==", "eq", "!=", "neq", "<", "<=", ">", ">=", "in", "not_in"]
              },
              "value": { "type": "string" },
              "values": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
